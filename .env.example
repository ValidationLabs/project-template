# Required for all ValidationLabs applications
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ---- E2E Testing ----
# Live URL for Playwright tests — set to your staging or production URL
PLAYWRIGHT_BASE_URL=https://your-app.run.app

# ---- GCP / Cloud Run ----
CLOUD_RUN_SERVICE=your-service-name
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ---- AI ----
GEMINI_API_KEY=your-gemini-api-key
# Optional: restrict to specific models
# GEMINI_MODEL=gemini-2.5-flash

# ---- Firebase ----
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# ---- Backend / Logic Core (if using functions/ service) ----
GROUNDING_BUCKET=your-project.appspot.com
PORT=8080

# ---- Optional: Feature Flags ----
# FEATURE_ANALYTICS=true
# FEATURE_MULTITENANCY=true
